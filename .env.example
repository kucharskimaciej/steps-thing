# Convex
# Created by `pnpm convex:dev` after selecting or creating a Convex project.
CONVEX_DEPLOYMENT=dev:your-project-name
NEXT_PUBLIC_CONVEX_URL=https://your-project-name.convex.cloud

# Clerk
# Retrieve these from the Clerk Dashboard API keys page.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key

# Clerk issuer configured for Convex.
# In development this usually looks like:
# https://your-clerk-app.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-app.clerk.accounts.dev

# App auth routes.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/feed
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/feed
