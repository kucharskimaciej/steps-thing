+"use client";
+
+import { useState } from "react";
+import { VideoUploadInput } from "@/components/video/video-upload-input";
+import type { StepVideo } from "@/lib/video/storage-client";
+
+export default function VideoUploadHarnessPage() {
+  const [videos, setVideos] = useState<StepVideo[]>([]);
+  const [touched, setTouched] = useState(false);
+
+  return (
+    <main className="p-8">
+      <VideoUploadInput
+        videos={videos}
+        existingMatches={[]}
+        onSelect={setVideos}
+        onTouched={() => setTouched(true)}
+        requestUpload={async ({ hash }) => ({
+          uploadUrl: "data:,ok",
+          storageKey: `videos/test/${hash}`,
+        })}
+        onError={() => undefined}
+      />
+      <p data-testid="harness-state">{touched ? "touched" : "untouched"}</p>
+    </main>
+  );
+}
diff --git a/components/video/step-video-upload-field.tsx b/components/video/step-video-upload-field.tsx
new file mode 100644
