 NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
 NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/feed
 NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/feed
+
+# Google Cloud Storage signed video uploads.
+GCS_BUCKET_NAME=your-video-bucket
+GCS_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
