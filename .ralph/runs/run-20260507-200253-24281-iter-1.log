+      storageKey: "videos/user-a/hash-b",
+    });
+
+    await expect(
+      uploadVideoForStep({
+        file: fileWithHashName(),
+        hash: "hash-b",
+        existing: null,
+        requestUpload,
+        upload,
+      }),
+    ).resolves.toEqual({
