+  matchedCount: number;
+  onClick: () => void;
+};
+
+function matchLabel(count: number) {
+  return count === 1 ? "1 match" : `${count} matches`;
+}
+
+export function SearchButton({
+  isActive,
+  matchedCount,
+  onClick,
+}: SearchButtonProps) {
+  return (
+    <button
+      type="button"
