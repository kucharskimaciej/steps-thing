+  };
+});
+
+vi.mock("@/components/video/step-video-upload-field", () => ({
+  StepVideoUploadField: () => <div>Video upload field</div>,
+}));
+
+describe("EditStepWorkflow", () => {
+  beforeEach(() => {
+    mocks.updateStep.mockReset();
