+        };
+      }
+
+      return [
+        existingStep,
+        {
+          _id: "step-related",
+          name: "Shadow exit",
+          videos: [
+            {
+              hash: "hash-related",
+              storageKey: "owners/user/videos/hash-related.mp4",
+            },
+          ],
