+  updateStep: vi.fn(),
+  push: vi.fn(),
+  stepForEdit: undefined as unknown,
+}));
+
+const existingStep = {
+  _id: "step-edit",
+  name: "Shadow turn",
+  videos: [
+    {
+      hash: "hash-video",
+      storageKey: "owners/user/videos/hash-video.mp4",
+    },
+  ],
+  difficulty: 3,
+  feeling: ["semba"],
+  kind: "step",
+  tags: ["turn"],
+  artists: ["Petchu"],
+  notes: "Keep frame",
+  smartTags: ["Shadow position"],
