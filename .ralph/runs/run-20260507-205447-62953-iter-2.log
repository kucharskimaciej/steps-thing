import { clerkMiddleware, createRouteMatcher } from "@clerk/nextjs/server";
import { protectedRoutePatterns } from "@/lib/auth/routes";

const isProtectedRoute = createRouteMatcher(protectedRoutePatterns);

export default clerkMiddleware(async (auth, req) => {
  if (isProtectedRoute(req)) {
    await auth.protect();
  }
});

export const config = {
  matcher: [
    "/((?!_next|[^?]*\\.(?:html?|css|js(?!on)|jpe?g|webp|png|gif|svg|ttf|woff2?|ico|csv|docx?|xlsx?|zip|webmanifest)).*)",
    "/(api|trpc)(.*)",
  ],
};
export const protectedRoutePatterns = [
  "/feed(.*)",
  "/steps(.*)",
  "/sessions(.*)",
  "/historical-sessions(.*)",
];

export function isProtectedPathname(pathname: string) {
  return (
    pathname === "/feed" ||
    pathname.startsWith("/feed/") ||
    pathname === "/steps" ||
    pathname.startsWith("/steps/") ||
    pathname === "/sessions" ||
    pathname.startsWith("/sessions/") ||
    pathname === "/historical-sessions" ||
    pathname.startsWith("/historical-sessions/")
  );
}

