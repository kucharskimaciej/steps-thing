+  ctx: MutationCtx;
+  ownerId: string;
+  mergeVariationKeys: string[] | undefined;
+  variationKey: string;
+  now: number;
+}) {
+  const keys = new Set(
+    (mergeVariationKeys ?? [])
+      .map((key) => key.trim())
+      .filter((key) => key.length > 0 && key !== variationKey),
+  );
+
+  if (keys.size === 0) {
+    return;
+  }
