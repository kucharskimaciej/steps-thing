+          artists: ["Petchu"],
+        };
+      }
+
+      return [
+        {
+          _id: "step-shadow",
+          name: "Shadow turn",
+          variationKey: "group-shadow",
+          tokens: ["shadow", "turn", "shadow|turn"],
+          tags: ["turn"],
+          smartTags: ["Shadow position"],
+          artists: ["Petchu"],
+          kind: "step",
+          difficulty: 3,
+          updatedAt: 20,
+        },
+        {
+          _id: "step-basic",
+          name: "Basic",
+          variationKey: "group-basic",
+          tokens: ["basic"],
+          tags: ["frame"],
+          smartTags: [],
+          artists: [],
+          kind: "step",
+          difficulty: 1,
+          updatedAt: 10,
+        },
+      ];
