+          tags: ["frame"],
+          smartTags: [],
+          artists: [],
+          kind: "step",
+          difficulty: 1,
+          updatedAt: 10,
+        },
+      ];
+    },
+  };
+});
+
+vi.mock("@/components/video/step-video-upload-field", () => ({
