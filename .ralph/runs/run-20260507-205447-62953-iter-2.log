+        name: "Basic",
+        variationKey: "group-basic",
+        tokens: ["basic"],
+        tags: ["frame"],
+        smartTags: [],
+        artists: [],
+        kind: "step",
+        difficulty: 1,
+        updatedAt: 10,
+      },
+    ];
+  },
+}));
