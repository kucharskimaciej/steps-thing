+  }) => (
+    <button
+      type="button"
+      onClick={() =>
+        onVideosChange([
+          {
+            hash: "hash-video",
+            storageKey: "owners/user/videos/hash-video.mp4",
+          },
+        ])
+      }
+    >
+      Add mocked video
+    </button>
