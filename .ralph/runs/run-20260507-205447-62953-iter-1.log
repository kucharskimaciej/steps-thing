      scoreVariationCandidate({
        sourceTokens: ["a", "a|b", "a|b|c", "x"],
        candidateTokens: ["a", "a|b", "a|b|c", "a|b|c|d"],
        sourceTags: ["first", "second", "third"],
        candidateTags: ["third", "first", "second"],
