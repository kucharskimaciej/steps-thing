+          { step: step("newer-update", { updatedAt: 20 }), score: 0 },
+        ],
+        { type: "VIEW_COUNT", direction: "DESCENDING" },
+      ).map((result) => result.step._id),
+    ).toEqual(["older-update", "newer-update"]);
