+  return {
+    _id: id,
+    name: id,
+    tags: [],
+    smartTags: [],
+    artists: [],
+    feeling: [],
+    viewRecords: [],
+    practiceRecords: [],
+    createdAt: 0,
+    updatedAt: 0,
+    ...overrides,
+  };
+}
+
+const baseState: SearchState = {
