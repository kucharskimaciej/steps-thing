+
+    expect(results.map((result) => result.step._id)).toEqual(["urban"]);
+  });
+});
+
+describe("scoreSearchResult", () => {
+  it("adds text, included tag, and positive feeling score", () => {
+    const result = querySearch([
+      step("scored", {
+        name: "Shadow turn",
+        tags: ["turn"],
