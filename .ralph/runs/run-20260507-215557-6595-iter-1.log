+  type SearchState,
+  type SearchableStep,
+} from "./types";
+
+const FUZZY_THRESHOLD = 0.4;
+
+function normalizeText(value: string): string {
+  return value
+    .toLocaleLowerCase("pl-PL")
+    .normalize("NFD")
+    .replace(/\p{Diacritic}/gu, "");
+}
