+        artistOptions={existing?.artists}
+        onEditStep={openInlineStepEdit}
       />
       <InlineStepEditModal
         stepId={editingStepId}
         isOpen={isInlineStepEditOpen}
         onClose={closeInlineStepEdit}
       />
-    </main>
+    </>
   );
 }
