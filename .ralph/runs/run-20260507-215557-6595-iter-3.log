diff --git a/components/steps/step-tags.tsx b/components/steps/step-tags.tsx
new file mode 100644
index 0000000000000000000000000000000000000000..28fe31313327c5b573dbd2c7df4b5b71a3f4a13e
--- /dev/null
+++ b/components/steps/step-tags.tsx
@@ -0,0 +1,25 @@
+type StepTagsProps = {
+  values: string[];
+  limit?: number;
+};
+
+export function StepTags({ values, limit = 12 }: StepTagsProps) {
+  const unique = [...new Set(values.filter((value) => value.trim().length > 0))];
+
+  if (unique.length === 0) {
+    return null;
+  }
+
+  return (
+    <ul className="flex flex-wrap gap-1.5" aria-label="Step tags">
+      {unique.slice(0, limit).map((tag) => (
+        <li
+          key={tag}
+          className="rounded-md bg-[var(--muted)] px-2 py-1 text-xs text-[var(--foreground)]"
+        >
+          {tag}
+        </li>
+      ))}
+    </ul>
+  );
+}
