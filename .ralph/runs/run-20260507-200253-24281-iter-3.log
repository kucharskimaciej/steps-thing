+};
+
+export function VideoModal({
+  open,
+  videoUrl,
+  snapshotUrl,
+  width,
+  height,
+  onClose,
+}: VideoModalProps) {
+  if (!open) {
+    return null;
+  }
+
+  return (
+    <div
+      role="dialog"
+      aria-modal="true"
+      aria-label="Full size video"
