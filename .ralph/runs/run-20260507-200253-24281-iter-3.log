+
+type VideoModalProps = {
+  open: boolean;
+  videoUrl: string;
+  snapshotUrl?: string;
+  width?: number;
+  height?: number;
+  onClose: () => void;
+};
+
+export function VideoModal({
+  open,
+  videoUrl,
+  snapshotUrl,
+  width,
+  height,
